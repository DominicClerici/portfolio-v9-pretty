---
import ProjectDialog from "./ProjectDialog.astro";

const projects = [
  {
    id: "dispatch",
    title: "DISPATCH",
    tech: "Astro / AI",
    icon: `<svg viewBox="36.5 55 141 90" xmlns="http://www.w3.org/2000/svg" class="w-9 h-9 text-on-surface/85"><text x="84" y="143" text-anchor="middle" font-family="'Libre Baskerville', Georgia, serif" font-size="120" font-weight="700" fill="currentColor">D</text><circle cx="163" cy="100" r="14" fill="#00c853" /></svg>`,
    description:
      "A daily snapshot of the tech industry, compressing the last 24 hours of tech news into a 10 minute read.",
    image: "/photos/dispatch.webp",
    alt: "Dispatch project screenshot",
    layout: "image-left",
    mobileObjectPosition: "top center",
    githubUrl: "https://github.com/DominicClerici/dispatch",
    websiteUrl: "https://dispatch.dominicclerici.com/",
    techStack: ["Astro", "TypeScript", "OpenAI API", "Tailwind CSS", "Vercel"],
    descriptionParagraphs: [] as string[],
  },
  {
    id: "meridian",
    title: "MERIDIAN",
    tech: "Vanilla JS",
    icon: `<svg viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" class="w-9 h-9"><g transform="scale(1.25490196) translate(-52,-52)"><polygon points="256,52 296,160 256,140 216,160" fill="#2dd4bf" opacity="0.65" /><polygon points="460,256 340,296 360,256 340,216" fill="#00ff41" opacity="0.65" /><polygon points="256,460 216,340 256,360 296,340" fill="#c45a3c" opacity="0.65" /><polygon points="52,256 172,216 152,256 172,296" fill="#2563eb" opacity="0.65" /><circle cx="256" cy="256" r="35" fill="currentColor" /></g></svg>`,
    description:
      "A new tab Chrome and Firefox extension with zero npm dependencies, full customization, and powerful integrations.",
    image: "/photos/meridian.webp",
    alt: "Meridian project screenshot",
    layout: "image-right",
    githubUrl: "https://github.com/DominicClerici/meridian",
    websiteUrl: "https://meridian.dominicclerici.com/",
    techStack: ["JavaScript", "HTML", "CSS", "Chrome Extensions API", "Firefox Add-ons"],
    descriptionParagraphs: [] as string[],
  },
  {
    id: "fuzzbox",
    title: "FUZZBOX",
    tech: "Typescript / Next.js / React Native",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-9 h-9"><rect width="32" height="32" fill="#131318"/><rect x="3" y="9.5" width="7" height="13" fill="none" stroke="#83fe56" stroke-width="2.5"/><rect x="12.5" y="9.5" width="7" height="13" fill="none" stroke="#d10088" stroke-width="2.5"/><rect x="22" y="9.5" width="7" height="13" fill="none" stroke="#7df4ff" stroke-width="2.5"/></svg>`,
    description:
      "The companion I wished I had when learning the guitar. Analyze your playing, create backing tracks, progressions, melodies, and share them with a community.",
    image: "/photos/fuzzbox.webp",
    alt: "Fuzzbox project screenshot",
    layout: "full-width",
    featured: true,
    websiteUrl: "https://fuzzbox.dominicclerici.com/",
    techStack: ["TypeScript", "Next.js", "React Native", "Prisma", "PostgreSQL"],
    descriptionParagraphs: [] as string[],
  },
];
---

<section id="work" class="relative bg-background py-16 md:py-32 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none bg-glow-bottom-left" aria-hidden="true"></div>
  <div class="absolute inset-0 pointer-events-none opacity-50 bg-dot-grid" aria-hidden="true"></div>

  <div class="relative px-3 sm:px-4 md:px-12 max-w-[1280px] mx-auto">
    <div class="flex items-center gap-4 mb-6 md:mb-12 md:border-b md:border-outline-variant/40 md:pb-4">
      <div class="md:flex-none">
        <h2 class="font-label text-primary text-xs md:text-sm uppercase tracking-[0.4em] md:mb-4">Selected Work</h2>
        <div class="hidden md:block w-48 h-px bg-primary"></div>
      </div>
      <div class="flex-grow h-px bg-primary/10 md:hidden"></div>
      <a
        href="https://github.com/DominicClerici"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex items-center gap-2 font-label text-on-surface-variant text-xs uppercase tracking-widest ml-auto group hover:text-primary transition-colors duration-150"
      >
        GitHub
        <svg class="w-3.5 h-3.5 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </a>
    </div>

    <div class="flex flex-col gap-16 md:gap-48">
      {projects.map((project) => (
        <article>
          {/* Two-column desktop layout */}
          {(project.layout === "image-left" || project.layout === "image-right") && (
            <div class="hidden md:grid grid-cols-12 gap-12 items-center">
              <div class={`col-span-7 aspect-[16/10] bg-surface-container-low overflow-hidden group border border-outline-variant/20 ${project.layout === "image-right" ? "order-last" : ""}`}>
                <img
                  src={project.image}
                  srcset={`${project.image} 1x, ${project.image.replace('.webp', '-2x.webp')} 2x`}
                  alt={project.alt}
                  class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-[40%] transition-all duration-250"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class={`col-span-5 space-y-6 ${project.layout === "image-right" ? "order-first" : ""}`}>
                <Fragment set:html={project.icon} />
                <h3 class="font-headline text-5xl text-on-surface">{project.title}</h3>
                <p class="font-label text-primary text-sm uppercase tracking-widest">{project.tech}</p>
                <p class="font-body text-on-surface-variant text-lg leading-relaxed">{project.description}</p>
                <div class="flex items-center gap-6 flex-wrap">
                  <button
                    type="button"
                    data-dialog-open={project.id}
                    class="font-label text-xs uppercase tracking-widest border border-primary/40 text-primary px-5 py-2.5 hover:bg-primary/10 transition-colors duration-200 cursor-pointer"
                  >
                    Read More
                  </button>
                  <a
                    href={project.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group inline-flex items-center gap-2 text-on-surface-variant font-label text-xs uppercase tracking-widest hover:text-primary transition-colors duration-150"
                  >
                    View Website
                    <svg class="w-3.5 h-3.5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                  </a>
                  {project.githubUrl && (
                    <a
                      href={project.githubUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group inline-flex items-center gap-2 text-on-surface-variant font-label text-xs uppercase tracking-widest hover:text-primary transition-colors duration-150"
                    >
                      GitHub
                      <svg class="w-3.5 h-3.5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          )}

          {/* Full-width desktop layout */}
          {project.layout === "full-width" && (
            <div class="hidden md:block bg-surface-container-low p-1 border border-primary/20">
              <div class="relative overflow-hidden aspect-[21/10] group">
                <img
                  src={project.image}
                  srcset={`${project.image} 1x, ${project.image.replace('.webp', '-2x.webp')} 2x`}
                  alt={project.alt}
                  class="w-full h-full object-cover grayscale opacity-40 group-hover:opacity-70 group-hover:grayscale-[40%] transition-all duration-250"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 p-12 flex flex-col justify-end items-end bg-gradient-to-t from-background via-transparent to-transparent">
                  <div class="max-w-[60%] space-y-6 text-right">
                    <h3 class="font-headline text-6xl text-on-surface">{project.title}</h3>
                    <p class="font-label text-primary text-sm uppercase tracking-widest">{project.tech}</p>
                    <p class="font-body text-on-surface-variant text-xl leading-relaxed">{project.description}</p>
                    <div class="flex items-center justify-end gap-6 flex-wrap">
                      <button
                        type="button"
                        data-dialog-open={project.id}
                        class="font-label text-xs uppercase tracking-widest border border-primary/40 text-primary px-5 py-2.5 hover:bg-primary/10 transition-colors duration-200 cursor-pointer"
                      >
                        Read More
                      </button>
                      <a
                        href={project.websiteUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group inline-flex items-center gap-2 text-on-surface-variant font-label text-xs uppercase tracking-widest hover:text-primary transition-colors duration-150"
                      >
                        View Website
                        <svg class="w-3.5 h-3.5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Mobile layout (shared) */}
          <div class="md:hidden flex flex-col gap-4">
            <div class="aspect-[21/10] bg-surface-container-high relative overflow-hidden">
              <img
                src={project.image}
                srcset={`${project.image} 1x, ${project.image.replace('.webp', '-2x.webp')} 2x`}
                alt={project.alt}
                class="w-full h-full object-cover grayscale-[40%]"
                style={project.mobileObjectPosition ? `object-position: ${project.mobileObjectPosition}` : undefined}
                loading="lazy"
                decoding="async"
              />
              {project.featured && (
                <div class="absolute bottom-4 right-4 bg-primary text-on-primary px-3 py-1 font-label text-[10px] uppercase font-bold tracking-widest">
                  Featured
                </div>
              )}
            </div>
            <div class="space-y-3">
              <Fragment set:html={project.icon} />
              <h3 class="font-headline text-2xl text-on-surface tracking-tighter">{project.title}</h3>
              <p class="font-body text-on-surface-variant text-sm leading-relaxed">{project.description}</p>
            </div>
            <div class="w-full h-px bg-primary/10"></div>
            <div class="flex flex-col gap-3">
              <button
                type="button"
                data-dialog-open={project.id}
                class="w-full py-3 border border-primary/40 text-primary font-label text-xs uppercase tracking-widest hover:bg-primary/10 transition-colors duration-200 cursor-pointer"
              >
                Read More
              </button>
              <div class="flex justify-center gap-6">
                {project.websiteUrl && (
                  <a
                    href={project.websiteUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest hover:text-primary transition-colors duration-150"
                  >
                    View Website
                  </a>
                )}
                {project.githubUrl && (
                  <a
                    href={project.githubUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-label text-on-surface-variant text-[10px] uppercase tracking-widest hover:text-primary transition-colors duration-150"
                  >
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<ProjectDialog projects={projects.map((p) => ({ id: p.id, title: p.title, icon: p.icon, githubUrl: p.githubUrl, websiteUrl: p.websiteUrl, techStack: p.techStack, descriptionParagraphs: p.descriptionParagraphs }))} />
