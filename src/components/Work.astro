---
const projects = [
  {
    number: "01",
    category: "Creative Engineering",
    title: "FRACT.AL",
    tech: "Canvas / WASM",
    techTags: ["Canvas", "WASM"],
    description:
      "A high-performance generative art engine built with Rust and WebAssembly, rendering complex recursive patterns in real-time.",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuBpVFl4XemdzBDzt8aHwqhRSfUKJeRkeMcjziRRPvE6pWp_NfVgcfUyDlNARD3mPhGMgPZ4WI-24yXkJe32umwpdqtdl2XHEl2zRUd4YHKH1PSuf3AHJ1A9oyeMcXbZFfDTqWpXBAezLvw1kJPx3xz9F5Yp7_C2AIE9CL-QO19IFm8DToEr0CWA1nwd51IXn2g0ZZf2saDR2SsPpzCTLD4wtnuMXydnwNfjIZoslTr2j6EmlVbf-XQe2SDdxJT2hof21carIc25FrtN",
    alt: "Abstract digital visualization of crystalline structures with golden geometric lines",
    layout: "image-left",
    mobileAspect: "aspect-square",
  },
  {
    number: "02",
    category: "Tooling",
    title: "SHELLCRAFT",
    tech: "Rust / CLI",
    techTags: ["Rust", "CLI"],
    description:
      "A minimalist command-line interface framework for building robust, type-safe terminal applications with expressive styling.",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuC_VnN5kq4Xu9drf4YL6JoGHDwwantGcqFLTI7QJ_2O-Nzc4vk8fu_Vxi_JT9gSMTIMN5N25T6u_iWbp8LNPaMBvdUlkEdfsgYEmZCyokNSJLIvttQv1mM-Yna5wvRFUGDYyNqEKapcas7RR9QeNmbJ0IVnNh6oQ6RI_2mUp5WfFD8lA8DJVEds2yUBfLTAV9WS956yDOhKAvFqcO6ztlP9okSdxTCKixwpjg5NnNRj75dajgyZH6msgwTKwVusQsSEnm4c6_DtkMZR",
    alt: "High contrast macro shot of vintage typewriter keys reflecting warm amber light",
    layout: "image-right",
    mobileAspect: "aspect-[4/3]",
  },
  {
    number: "03",
    category: "Systems",
    title: "GRIDLOCK",
    tech: "Canvas / TypeScript",
    techTags: ["Canvas", "TypeScript"],
    description:
      "An architectural visualization tool for mapping complex dependency trees and system hierarchies in large-scale software environments.",
    image:
      "https://lh3.googleusercontent.com/aida-public/AB6AXuB-ZMuOIz7uEVuRa8yPD-P5PnSVTNnDZrSQ5TvFPDW1D-c_eiphMFjc_cLUPy9Lx62xca3-_C4fcmB-iEJFP0niAOxSGE7mRDqpEILJLPja6y_uvktQT0mOX5WsfM-un6C1A00SD-vAuGfzEtlQ30wQOj55Ju6s1z9BamerklinCjUsZDbU7dC9gjRcfJRyEK-7Zbkhk7SzS5t-BjOnA2N0E2T3BbhoZzQfypMPbjErfG2R9HKBlCuBsNgVWWKJgUXFAyeZ_86mXd1h",
    alt: "Expansive view of interconnected satellite data nodes forming a luminous grid",
    layout: "full-width",
    mobileAspect: "aspect-[3/4]",
    featured: true,
  },
];
---

<section id="work" class="relative bg-background py-16 md:py-32 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none bg-glow-bottom-left" aria-hidden="true"></div>
  <div class="absolute inset-0 pointer-events-none opacity-50 bg-dot-grid" aria-hidden="true"></div>

  <div class="relative px-6 md:px-12 max-w-[1280px] mx-auto">
    <div class="flex items-center gap-4 mb-6 md:mb-12 md:border-b md:border-outline-variant/40 md:pb-4">
      <div class="md:flex-none">
        <h2 class="font-label text-primary text-xs md:text-sm uppercase tracking-[0.4em] md:mb-4">Selected Work</h2>
        <div class="hidden md:block w-48 h-px bg-primary"></div>
      </div>
      <div class="flex-grow h-px bg-primary/10 md:hidden"></div>
      <a
        href="https://github.com/DominicClerici"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex items-center gap-2 font-label text-on-surface-variant text-xs uppercase tracking-widest ml-auto group hover:text-primary transition-colors duration-150"
      >
        GitHub
        <svg class="w-3.5 h-3.5 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
      </a>
    </div>

    <div class="flex flex-col gap-16 md:gap-48">
      {projects.map((project) => (
        <article>
          {/* Two-column desktop layout */}
          {(project.layout === "image-left" || project.layout === "image-right") && (
            <div class="hidden md:grid grid-cols-12 gap-12 items-center">
              <div class={`col-span-7 aspect-[16/10] bg-surface-container-low overflow-hidden group border border-outline-variant/20 ${project.layout === "image-right" ? "order-last" : ""}`}>
                <img
                  src={project.image}
                  alt={project.alt}
                  class="w-full h-full object-cover grayscale opacity-60 group-hover:opacity-100 group-hover:grayscale-0 transition-all duration-700"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class={`col-span-5 space-y-6 ${project.layout === "image-right" ? "order-first" : ""}`}>
                <span class="font-label text-secondary text-xs uppercase tracking-[0.2em]">{project.number} / {project.category}</span>
                <h3 class="font-headline text-5xl text-on-surface">{project.title}</h3>
                <p class="font-label text-primary text-sm uppercase tracking-widest">{project.tech}</p>
                <p class="font-body text-on-surface-variant text-lg leading-relaxed">{project.description}</p>
                <a href="#" class="group inline-flex items-center gap-4 text-primary font-label text-sm uppercase tracking-widest">
                  View Project <svg class="w-4 h-4 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                </a>
              </div>
            </div>
          )}

          {/* Full-width desktop layout */}
          {project.layout === "full-width" && (
            <div class="hidden md:block bg-surface-container-low p-1 border border-primary/20">
              <div class="relative overflow-hidden aspect-[21/9] group">
                <img
                  src={project.image}
                  alt={project.alt}
                  class="w-full h-full object-cover grayscale opacity-40 group-hover:opacity-70 transition-all duration-1000"
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 p-12 flex flex-col justify-end bg-gradient-to-t from-background via-transparent to-transparent">
                  <div class="max-w-2xl space-y-6">
                    <span class="font-label text-secondary text-xs uppercase tracking-[0.2em]">{project.number} / {project.category}</span>
                    <h3 class="font-headline text-6xl text-on-surface">{project.title}</h3>
                    <p class="font-label text-primary text-sm uppercase tracking-widest">{project.tech}</p>
                    <p class="font-body text-on-surface-variant text-xl leading-relaxed">{project.description}</p>
                    <a href="#" class="group inline-flex items-center gap-4 text-primary font-label text-sm uppercase tracking-widest">
                      View Project <svg class="w-4 h-4 opacity-0 -translate-x-3 group-hover:opacity-100 group-hover:-translate-x-2 transition-all duration-150" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Mobile layout (shared) */}
          <div class="md:hidden flex flex-col gap-4">
            <div class={`${project.mobileAspect} bg-surface-container-high relative overflow-hidden`}>
              <img
                src={project.image}
                alt={project.alt}
                class="w-full h-full object-cover grayscale contrast-125"
                loading="lazy"
                decoding="async"
              />
              <span class="absolute top-4 left-4 font-label text-primary text-xs font-bold bg-surface p-1">{project.number}</span>
              {project.featured && (
                <div class="absolute bottom-4 right-4 bg-primary text-on-primary px-3 py-1 font-label text-[10px] uppercase font-bold tracking-widest">
                  Featured
                </div>
              )}
            </div>
            <div class="flex justify-between items-start">
              <h3 class="font-headline text-2xl text-on-surface tracking-tighter">{project.title}</h3>
              <div class="flex gap-2">
                {project.techTags.map((tag: string) => (
                  <span class="font-label text-secondary text-[9px] uppercase tracking-widest">{tag}</span>
                ))}
              </div>
            </div>
            <div class="w-full h-px bg-primary/10"></div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
