<section class="relative bg-section-quote py-24 md:py-48 px-6 md:px-12 border-y border-outline-variant/20 overflow-hidden">
  <!-- Vignette — darkens edges, draws focus to center (desktop only) -->
  <div
    class="hidden md:block absolute inset-0 pointer-events-none bg-vignette"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-5xl mx-auto md:text-center">
    <blockquote class="font-headline italic text-xl md:text-3xl lg:text-5xl text-on-surface leading-snug md:leading-tight mb-6 md:mb-12">
      "The most disastrous thing that you can ever learn is your first programming language."
    </blockquote>
    <cite class="font-label text-primary text-xs md:text-lg uppercase tracking-[0.25em] not-italic">
      — Alan Kay
    </cite>
  </div>
  <div class="absolute bottom-6 right-6 md:bottom-12 md:right-12 z-10">
    <p class="font-label text-[10px] md:text-xs text-outline/60 uppercase tracking-wider">
      "Eh, maybe..." — Dominic Clerici
    </p>
  </div>
</section>
