<section id="hero" class="relative min-h-[500px] md:min-h-[90svh] flex flex-col justify-end md:justify-center bg-surface-dim overflow-hidden">
  <div class="hidden md:block absolute left-3 md:left-12 top-0 bottom-0 w-px bg-secondary/30"></div>

  <div class="absolute right-0 top-0 bottom-0 w-1/2 hero-grid pointer-events-none" aria-hidden="true"></div>

  <!-- Tracer layer — same position as grid but with its own brighter mask -->
  <div class="absolute right-0 top-0 bottom-0 w-1/2 hero-grid-tracer-layer pointer-events-none" aria-hidden="true">
    <div class="hero-grid-tracer" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 max-w-[1920px] mx-auto w-full px-6 pt-12 pb-16 md:px-24 md:py-0">
    <div class="max-w-4xl">
    <h1 class="font-headline text-6xl md:text-7xl lg:text-9xl leading-none tracking-tight text-on-surface mb-4">
      Dominic<br class="md:hidden" /> Clerici
    </h1>
    <div class="flex flex-col md:flex-row gap-1 md:gap-x-6 mb-6 md:mb-8">
      <span class="font-label text-primary text-xs md:text-xl uppercase tracking-widest font-medium">Engineer & Designer</span>
      <span class="font-label text-secondary text-xs md:text-xl uppercase tracking-widest font-medium">New York</span>
    </div>
    <p class="font-headline text-lg md:text-2xl lg:text-4xl text-on-surface-variant max-w-[280px] md:max-w-2xl leading-relaxed mb-8 md:mb-12">
      I design and build software that's fast, useful, and worth looking at.
    </p>
      <div class="hidden md:block relative">
        <div class="w-full md:max-w-md h-px bg-primary/20 md:bg-primary"></div>
        <div class="absolute -left-3 md:-left-12 top-0 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-primary rounded-full" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<script>
  {
    const SPEED_MIN = 850;    // px per second
    const SPEED_MAX = 1500;   // px per second
    const MIN_DELAY = 1000;   // ms before next tracer
    const MAX_DELAY = 4000;   // ms before next tracer
    const GRID_SIZE = 40;     // must match background-size in CSS
    const TRACER_LENGTH = 100;      // white tracer gradient length in px
    const GOLD_TRACER_LENGTH = 200; // gold tracer gradient length in px
    const GOLD_CHANCE = 0.2;        // 20% chance of gold tracer
    const GOLD_COLOR = 'var(--color-primary)'; // #e2c28f

    const grid = document.querySelector('.hero-grid') as HTMLElement | null;
    const tracer = document.querySelector('.hero-grid-tracer') as HTMLElement | null;

    if (grid && tracer) {
      function getEligibleLines() {
        const gridWidth = grid!.offsetWidth;
        const gridHeight = grid!.offsetHeight;
        const screenThird = window.innerWidth / 3;

        // Vertical lines (for down-tracers): exclude rightmost 2 and
        // any further left than 1/3 of the screen from the right edge
        const minX = Math.max(0, Math.ceil((gridWidth - screenThird) / GRID_SIZE) * GRID_SIZE);
        const maxX = Math.floor(gridWidth / GRID_SIZE) * GRID_SIZE - 2 * GRID_SIZE;
        const verticalLines: number[] = [];
        for (let x = minX; x <= maxX; x += GRID_SIZE) verticalLines.push(x);

        // Horizontal lines (for left-tracers): exclude topmost 2 and bottommost 2
        const maxY = Math.floor(gridHeight / GRID_SIZE) * GRID_SIZE - 2 * GRID_SIZE;
        const horizontalLines: number[] = [];
        for (let y = 2 * GRID_SIZE; y <= maxY; y += GRID_SIZE) horizontalLines.push(y);

        return { verticalLines, horizontalLines, gridWidth, gridHeight };
      }

      function animateTracer() {
        const { verticalLines, horizontalLines, gridWidth, gridHeight } = getEligibleLines();

        // Pick direction, falling back if one set is empty
        let direction: 'down' | 'left';
        if (!verticalLines.length && !horizontalLines.length) { scheduleNext(); return; }
        else if (!verticalLines.length) direction = 'left';
        else if (!horizontalLines.length) direction = 'down';
        else direction = Math.random() < 0.5 ? 'down' : 'left';

        // Randomize speed and color variant
        const speed = SPEED_MIN + Math.random() * (SPEED_MAX - SPEED_MIN);
        const isGold = Math.random() < GOLD_CHANCE;
        const length = isGold ? GOLD_TRACER_LENGTH : TRACER_LENGTH;
        const color = isGold ? GOLD_COLOR : 'white';

        if (direction === 'down') {
          const x = verticalLines[Math.floor(Math.random() * verticalLines.length)];
          const startY = -length;
          const endY = gridHeight;
          const duration = (endY - startY) / speed;

          tracer!.style.width = '1px';
          tracer!.style.height = length + 'px';
          tracer!.style.background = `linear-gradient(to bottom, transparent, ${color})`;
          tracer!.dataset.dir = 'down';
          tracer!.style.left = x + 'px';
          tracer!.style.top = '0px';
          tracer!.style.transition = 'none';
          tracer!.style.transform = `translateY(${startY}px)`;
          tracer!.style.display = 'block';
          tracer!.offsetHeight; // force reflow

          tracer!.style.transition = `transform ${duration}s linear`;
          tracer!.style.transform = `translateY(${endY}px)`;
        } else {
          const y = horizontalLines[Math.floor(Math.random() * horizontalLines.length)];
          const startX = gridWidth;
          const endX = -length;
          const duration = (startX - endX) / speed;

          tracer!.style.height = '1px';
          tracer!.style.width = length + 'px';
          tracer!.style.background = `linear-gradient(to right, ${color}, transparent)`;
          tracer!.dataset.dir = 'left';
          tracer!.style.top = y + 'px';
          tracer!.style.left = '0px';
          tracer!.style.transition = 'none';
          tracer!.style.transform = `translateX(${startX}px)`;
          tracer!.style.display = 'block';
          tracer!.offsetHeight; // force reflow

          tracer!.style.transition = `transform ${duration}s linear`;
          tracer!.style.transform = `translateX(${endX}px)`;
        }

        tracer!.addEventListener('transitionend', () => {
          tracer!.style.display = 'none';
          scheduleNext();
        }, { once: true });
      }

      function scheduleNext() {
        const delay = MIN_DELAY + Math.random() * (MAX_DELAY - MIN_DELAY);
        setTimeout(animateTracer, delay);
      }

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        scheduleNext();
      }
    }
  }
</script>
