---
const year = new Date().getFullYear();
---

<footer class="w-full bg-background border-t border-primary/10">
  <div class="flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:items-end md:gap-0 md:text-left max-w-[1920px] mx-auto py-20 px-3 sm:px-4 md:px-8">
    <div class="font-label text-sm uppercase tracking-[0.2em] text-secondary/60 group cursor-default leading-relaxed flex flex-col items-center md:items-start">
      <span class="flex items-center gap-2">
        Made with
        <svg
          class="w-4 h-4 text-primary group-hover:text-red-500 transition-colors duration-150"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        ><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
      </span>
      <span>by Dominic Clerici</span>
    </div>
    <p class="font-label text-[10px] uppercase tracking-widest text-outline md:text-secondary/60">
      &copy; {year} — Dominic Clerici
    </p>
  </div>
</footer>
