---
const entries = [
  {
    period: "2025 — Now",
    company: "Rumor",
    title: "Full Stack Developer",
    description: "Building the platform behind Rumor — a private network connecting people to exclusive cultural events. Most of my time goes toward the host dashboard and mobile apps, everything from event creation and guest management to real-time analytics. Small team, so I touch most of the stack, from the database layer up to what users see on their phones.",
    skills: ["Full Stack", "Mobile", "Cloud Infrastructure"],
    tags: ["TypeScript", "PostgreSQL", "AWS Lambda", "Next.js", "React Native", "Swift"],
    url: "https://www.therumor.com/",
  },
  {
    period: "2024 — 2026",
    company: "Squib",
    title: "Founding Engineer",
    description: "First engineer at an AI research lab building autonomous agents that model human behavior. I helped build Persona, a product that creates AI-powered social profiles — digital twins that grow audiences and predict how communities will respond before a campaign launches. Early-stage startup, so I had my hands in everything from agent architecture to the product interface.",
    skills: ["AI/ML", "Autonomous Agents", "Growth Engineering"],
    tags: ["Go", "TypeScript", "Python", "PostgreSQL"],
    url: "https://www.heysquib.com/",
  },
  {
    period: "2021 — 2022",
    company: "Artesian Builds",
    title: "Full Stack Developer",
    description: "Helped overhaul the company website — better design, tighter SEO, load times dropped about 40%. Also built internal tools for tracking sponsorship metrics and Twitch creator stats, which gave management real numbers instead of gut feelings. Small team, learned a lot about wearing different hats and shipping quickly.",
    skills: ["Full Stack", "Internal Tooling", "SEO", "Data Analysis"],
    tags: ["WordPress", "Elementor", "Electron", "Python", "PostgreSQL"],
    url: "https://en.wikipedia.org/wiki/Artesian_Builds",
  },
  {
    period: "2019",
    company: "McDonalds",
    title: "Crew Member",
    description: "Got me my first car at 16 — a '93 Miata with 220k miles on it. I still think about that car more than I probably should.",
    skills: ["Deep Fryer", "Cash Register", "Drive-Thru", "Customer Service"],
    tags: ["Ice Cream Machine (Broken)", "McFlurry Assembly", "Headset Comms"],
    url: "https://www.mcdonalds.com/us/en-us.html",
  },
];

---

<section id="career" class="relative bg-surface-dim py-16 md:py-32 overflow-hidden">
  <!-- Soft gold light — large, off-screen top-right -->
  <div
    class="absolute inset-0 pointer-events-none bg-glow-top-right"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-[1280px] mx-auto px-6 md:px-24">
    <div class="flex items-center gap-4 mb-12 md:mb-20">
      <h2 class="font-label text-xs tracking-[0.4em] uppercase text-primary md:border-b md:border-primary/30 md:pb-2 shrink-0">
        Recently
      </h2>
      <div class="flex-grow h-px bg-primary/10 md:hidden"></div>
    </div>

    <div class="relative pl-8 md:pl-12">
      <!-- Vertical timeline line — extends above with fade, and below into section padding -->
      <div
        class="absolute left-0 md:left-[7px] -top-[50px] -bottom-16 md:-bottom-32 w-px timeline-gradient"
        aria-hidden="true"
      ></div>

      <div class="flex flex-col gap-12 md:gap-24">
        {
          entries.map((entry) => (
            <div
              class="relative"
            >
              <div
                class="md:hidden absolute -left-8 top-1.5 w-2 h-2 bg-primary rounded-full -translate-x-1/2"
                aria-hidden="true"
              />
              <div
                class="hidden md:flex absolute -left-12 top-3 w-4 h-4 bg-background border border-primary items-center justify-center"
                aria-hidden="true"
              >
                <div class="w-1.5 h-1.5 bg-primary" />
              </div>

              <span class="font-label text-[10px] tracking-widest text-secondary uppercase block mb-1 md:mb-2">
                {entry.period}
              </span>

              <a
                href={entry.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-2"
              >
                <h3 class="font-headline text-xl md:text-5xl text-primary">
                  {entry.company}
                </h3>
                <svg
                  class="w-6 h-6 text-primary opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:-translate-x-0.5 transition-all duration-150"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                ><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
              </a>

              {entry.title && (
                <span class="font-label text-[10px] md:text-xs tracking-widest text-on-surface-variant uppercase block mt-1 md:mt-2">
                  {entry.title}
                </span>
              )}

              {entry.description && (
                <p class="font-body text-outline md:text-on-surface-variant text-sm md:text-base mt-2 md:mt-4 max-w-xl">
                  {entry.description}
                </p>
              )}

              {entry.skills && entry.skills.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-3 md:mt-5">
                  {entry.skills.map((skill) => (
                    <span class="font-label text-[9px] md:text-[10px] px-2 py-1 border border-primary/30 text-primary uppercase tracking-wider">
                      {skill}
                    </span>
                  ))}
                </div>
              )}

              {entry.tags && entry.tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-2">
                  {entry.tags.map((tag) => (
                    <span class="font-label text-[9px] md:text-[10px] px-2 py-1 border border-secondary/20 text-secondary uppercase tracking-wider">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
