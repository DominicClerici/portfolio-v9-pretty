---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Favicon Concepts" description="Favicon exploration for dominicclerici.com">
  <main class="min-h-svh bg-surface-container-lowest py-16 px-3 sm:px-4 md:px-12">
    <div class="max-w-5xl mx-auto">
      <h1 class="font-headline text-4xl md:text-5xl text-on-surface mb-2">Favicon Concepts</h1>
      <p class="font-body text-on-surface-variant text-sm md:text-base mb-12 max-w-xl">
        Ten directions for a new favicon. Each shown at display size and actual 32&times;32 / 16&times;16 scale.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- 1: Refined Bracket D -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">01</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Refined Bracket</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M20 16 L32 16 Q44 16 44 28 L44 36 Q44 48 32 48 L20 48"
                      fill="none" stroke="#e2c28f" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="20" cy="32" r="1.5" fill="#e2c28f" opacity="0.5"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M20 16 L32 16 Q44 16 44 28 L44 36 Q44 48 32 48 L20 48"
                      fill="none" stroke="#e2c28f" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="20" cy="32" r="1.5" fill="#e2c28f" opacity="0.5"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M20 16 L32 16 Q44 16 44 28 L44 36 Q44 48 32 48 L20 48"
                      fill="none" stroke="#e2c28f" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="20" cy="32" r="1.5" fill="#e2c28f" opacity="0.5"/>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            Evolution of the current mark. Softer radius, rounded caps, subtle dot accent at the open edge.
          </p>
        </div>

        <!-- 2: Monogram DC -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">02</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Monogram DC</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M16 16 L16 48 L28 48 Q38 48 38 38 L38 26 Q38 16 28 16 Z"
                      fill="none" stroke="#e2c28f" stroke-width="4.5" stroke-linejoin="round"/>
                <path d="M48 18 Q36 18 36 28 L36 36 Q36 46 48 46"
                      fill="none" stroke="#a9cfb8" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M16 16 L16 48 L28 48 Q38 48 38 38 L38 26 Q38 16 28 16 Z"
                      fill="none" stroke="#e2c28f" stroke-width="4.5" stroke-linejoin="round"/>
                <path d="M48 18 Q36 18 36 28 L36 36 Q36 46 48 46"
                      fill="none" stroke="#a9cfb8" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M16 16 L16 48 L28 48 Q38 48 38 38 L38 26 Q38 16 28 16 Z"
                      fill="none" stroke="#e2c28f" stroke-width="4.5" stroke-linejoin="round"/>
                <path d="M48 18 Q36 18 36 28 L36 36 Q36 46 48 46"
                      fill="none" stroke="#a9cfb8" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            Interlocking D and C using both brand colors. The C nests inside the D's counter space.
          </p>
        </div>

        <!-- 3: Terminal Prompt -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">03</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Terminal Prompt</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <text x="10" y="42" font-family="monospace" font-size="30" font-weight="700" fill="#e2c28f">&gt;</text>
                <rect x="36" y="22" width="3.5" height="22" rx="1" fill="#a9cfb8" opacity="0.9"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <text x="10" y="42" font-family="monospace" font-size="30" font-weight="700" fill="#e2c28f">&gt;</text>
                <rect x="36" y="22" width="3.5" height="22" rx="1" fill="#a9cfb8" opacity="0.9"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <text x="10" y="42" font-family="monospace" font-size="30" font-weight="700" fill="#e2c28f">&gt;</text>
                <rect x="36" y="22" width="3.5" height="22" rx="1" fill="#a9cfb8" opacity="0.9"/>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            The terminal prompt motif that already lives in your site — gold chevron, sage cursor. Pure engineer identity.
          </p>
        </div>

        <!-- 4: Grid Tracer -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">04</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Grid Tracer</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <line x1="22" y1="8" x2="22" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="32" y1="8" x2="32" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="42" y1="8" x2="42" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="22" x2="56" y2="22" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="32" x2="56" y2="32" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="42" x2="56" y2="42" stroke="#323533" stroke-width="1"/>
                <line x1="32" y1="8" x2="32" y2="32" stroke="#e2c28f" stroke-width="2.5" stroke-linecap="round">
                  <animate attributeName="y2" values="8;32;32" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1"/>
                  <animate attributeName="opacity" values="0;1;0.3" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1"/>
                </line>
                <line x1="32" y1="32" x2="42" y2="32" stroke="#a9cfb8" stroke-width="2.5" stroke-linecap="round">
                  <animate attributeName="x2" values="32;42;42" dur="2s" repeatCount="indefinite" keyTimes="0;0.6;1"/>
                  <animate attributeName="opacity" values="0;0;1" dur="2s" repeatCount="indefinite" keyTimes="0;0.5;1"/>
                </line>
                <circle cx="32" cy="32" r="2.5" fill="#e2c28f"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <line x1="22" y1="8" x2="22" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="32" y1="8" x2="32" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="42" y1="8" x2="42" y2="56" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="22" x2="56" y2="22" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="32" x2="56" y2="32" stroke="#323533" stroke-width="1"/>
                <line x1="8" y1="42" x2="56" y2="42" stroke="#323533" stroke-width="1"/>
                <circle cx="32" cy="32" r="2.5" fill="#e2c28f"/>
                <line x1="32" y1="12" x2="32" y2="30" stroke="#e2c28f" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
                <line x1="34" y1="32" x2="42" y2="32" stroke="#a9cfb8" stroke-width="2" stroke-linecap="round" opacity="0.7"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <line x1="22" y1="8" x2="22" y2="56" stroke="#323533" stroke-width="1.5"/>
                <line x1="32" y1="8" x2="32" y2="56" stroke="#323533" stroke-width="1.5"/>
                <line x1="42" y1="8" x2="42" y2="56" stroke="#323533" stroke-width="1.5"/>
                <line x1="8" y1="22" x2="56" y2="22" stroke="#323533" stroke-width="1.5"/>
                <line x1="8" y1="32" x2="56" y2="32" stroke="#323533" stroke-width="1.5"/>
                <line x1="8" y1="42" x2="56" y2="42" stroke="#323533" stroke-width="1.5"/>
                <circle cx="32" cy="32" r="3" fill="#e2c28f"/>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            Miniature version of the hero grid tracer animation. Animated at display size, static glow at small scale.
          </p>
        </div>

        <!-- 5: Geometric Slab D -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">05</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Geometric Slab</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M18 14 L18 50 L34 50 Q48 50 48 36 L48 28 Q48 14 34 14 Z"
                      fill="#e2c28f"/>
                <path d="M24 20 L24 44 L32 44 Q40 44 40 36 L40 28 Q40 20 32 20 Z"
                      fill="#111412"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M18 14 L18 50 L34 50 Q48 50 48 36 L48 28 Q48 14 34 14 Z"
                      fill="#e2c28f"/>
                <path d="M24 20 L24 44 L32 44 Q40 44 40 36 L40 28 Q40 20 32 20 Z"
                      fill="#111412"/>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <path d="M18 14 L18 50 L34 50 Q48 50 48 36 L48 28 Q48 14 34 14 Z"
                      fill="#e2c28f"/>
                <path d="M24 20 L24 44 L32 44 Q40 44 40 36 L40 28 Q40 20 32 20 Z"
                      fill="#111412"/>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            Solid gold D with cut-out counter. Bold, confident, reads clearly at any size.
          </p>
        </div>

        <!-- 6: Dot Matrix D -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">06</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Dot Matrix</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g fill="#e2c28f">
                  <!-- Column 1 (stem) -->
                  <circle cx="18" cy="14" r="2.5"/>
                  <circle cx="18" cy="22" r="2.5"/>
                  <circle cx="18" cy="30" r="2.5"/>
                  <circle cx="18" cy="38" r="2.5"/>
                  <circle cx="18" cy="46" r="2.5"/>
                  <!-- Top -->
                  <circle cx="26" cy="14" r="2.5"/>
                  <circle cx="34" cy="16" r="2.5"/>
                  <!-- Right curve -->
                  <circle cx="40" cy="22" r="2.5"/>
                  <circle cx="44" cy="30" r="2.5"/>
                  <circle cx="40" cy="38" r="2.5"/>
                  <!-- Bottom -->
                  <circle cx="34" cy="44" r="2.5"/>
                  <circle cx="26" cy="46" r="2.5"/>
                </g>
                <g fill="#a9cfb8" opacity="0.3">
                  <circle cx="26" cy="22" r="1.5"/>
                  <circle cx="26" cy="30" r="1.5"/>
                  <circle cx="26" cy="38" r="1.5"/>
                  <circle cx="34" cy="30" r="1.5"/>
                </g>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g fill="#e2c28f">
                  <circle cx="18" cy="14" r="2.5"/>
                  <circle cx="18" cy="22" r="2.5"/>
                  <circle cx="18" cy="30" r="2.5"/>
                  <circle cx="18" cy="38" r="2.5"/>
                  <circle cx="18" cy="46" r="2.5"/>
                  <circle cx="26" cy="14" r="2.5"/>
                  <circle cx="34" cy="16" r="2.5"/>
                  <circle cx="40" cy="22" r="2.5"/>
                  <circle cx="44" cy="30" r="2.5"/>
                  <circle cx="40" cy="38" r="2.5"/>
                  <circle cx="34" cy="44" r="2.5"/>
                  <circle cx="26" cy="46" r="2.5"/>
                </g>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g fill="#e2c28f">
                  <circle cx="18" cy="14" r="3"/>
                  <circle cx="18" cy="22" r="3"/>
                  <circle cx="18" cy="30" r="3"/>
                  <circle cx="18" cy="38" r="3"/>
                  <circle cx="18" cy="46" r="3"/>
                  <circle cx="26" cy="14" r="3"/>
                  <circle cx="34" cy="16" r="3"/>
                  <circle cx="40" cy="22" r="3"/>
                  <circle cx="44" cy="30" r="3"/>
                  <circle cx="40" cy="38" r="3"/>
                  <circle cx="34" cy="44" r="3"/>
                  <circle cx="26" cy="46" r="3"/>
                </g>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            D constructed from dots — echoes the dot-grid background pattern. Inner ghost dots in sage add depth.
          </p>
        </div>

        <!-- 7: Stacked Lines D -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">07</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Stacked Lines</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g stroke-linecap="round" stroke-width="3.5" fill="none">
                  <line x1="16" y1="13" x2="30" y2="13" stroke="#e2c28f"/>
                  <line x1="16" y1="20" x2="38" y2="20" stroke="#e2c28f" opacity="0.9"/>
                  <line x1="16" y1="27" x2="43" y2="27" stroke="#e2c28f" opacity="0.8"/>
                  <line x1="16" y1="34" x2="46" y2="34" stroke="#e2c28f" opacity="0.85"/>
                  <line x1="16" y1="41" x2="43" y2="41" stroke="#e2c28f" opacity="0.8"/>
                  <line x1="16" y1="48" x2="38" y2="48" stroke="#e2c28f" opacity="0.9"/>
                  <line x1="16" y1="55" x2="30" y2="55" stroke="#e2c28f"/>
                </g>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g stroke-linecap="round" stroke-width="3.5" fill="none">
                  <line x1="16" y1="13" x2="30" y2="13" stroke="#e2c28f"/>
                  <line x1="16" y1="20" x2="38" y2="20" stroke="#e2c28f" opacity="0.9"/>
                  <line x1="16" y1="27" x2="43" y2="27" stroke="#e2c28f" opacity="0.8"/>
                  <line x1="16" y1="34" x2="46" y2="34" stroke="#e2c28f" opacity="0.85"/>
                  <line x1="16" y1="41" x2="43" y2="41" stroke="#e2c28f" opacity="0.8"/>
                  <line x1="16" y1="48" x2="38" y2="48" stroke="#e2c28f" opacity="0.9"/>
                  <line x1="16" y1="55" x2="30" y2="55" stroke="#e2c28f"/>
                </g>
              </svg>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="16" height="16">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <g stroke-linecap="round" stroke-width="4" fill="none">
                  <line x1="16" y1="13" x2="30" y2="13" stroke="#e2c28f"/>
                  <line x1="16" y1="20" x2="38" y2="20" stroke="#e2c28f"/>
                  <line x1="16" y1="27" x2="43" y2="27" stroke="#e2c28f"/>
                  <line x1="16" y1="34" x2="46" y2="34" stroke="#e2c28f"/>
                  <line x1="16" y1="41" x2="43" y2="41" stroke="#e2c28f"/>
                  <line x1="16" y1="48" x2="38" y2="48" stroke="#e2c28f"/>
                  <line x1="16" y1="55" x2="30" y2="55" stroke="#e2c28f"/>
                </g>
              </svg>
            </div>
          </div>
          <p class="font-body text-xs text-on-surface-variant mt-4">
            Horizontal lines that form a D silhouette — like scan lines or a text editor. Retro-tech meets typography.
          </p>
        </div>

        <!-- 8: Serif Ligature -->
        <div class="group border border-outline-variant/20 rounded-lg p-6 bg-surface-container/50 hover:bg-surface-container-high/40 transition-colors duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="font-label text-xs uppercase tracking-[0.25em] text-primary">08</span>
            <span class="font-label text-xs uppercase tracking-[0.2em] text-on-surface-variant">Serif Letterform</span>
          </div>
          <div class="flex items-end gap-6">
            <div class="bg-background rounded-lg p-4 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="128" height="128">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <defs>
                  <linearGradient id="g8" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#e2c28f"/>
                    <stop offset="100%" stop-color="#b89a6a"/>
                  </linearGradient>
                </defs>
                <text x="20" y="48" font-family="Georgia, 'Times New Roman', serif" font-size="44" font-weight="700" font-style="italic" fill="url(#g8)">d</text>
                <line x1="16" y1="52" x2="48" y2="52" stroke="#e2c28f" stroke-width="2" opacity="0.4"/>
              </svg>
            </div>
            <div class="flex gap-3 items-end pb-2">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="32" height="32">
                <rect width="64" height="64" rx="10" fill="#111412"/>
                <text x="20" y="48" font-family="Georgia, 'Times New Roman', serif" font-size="44" font-weight="700" font-style="italic" fill="#e2c28f">d</text>
